{
  "bot": {
    "name": "moomoo-paper-bot",
    "environment": "dev",
    "data_dir": "data/runtime",
    "metrics_host": "127.0.0.1",
    "metrics_port": 9200,
    "loop_interval_ms": 5000,
    "max_iterations": 100
  },
  "risk": {
    "max_position_notional": 5000.0,
    "max_daily_loss": 500.0,
    "max_consecutive_losses": 3,
    "min_order_interval_seconds": 60
  },
  "strategy": {
    "symbol": "US.AAPL",
    "base_price": 200.0,
    "signal_threshold_bps": 10.0,
    "metadata": {
      "strategy_type": "momentum",
      "window": "10"
    }
  },
  "market_data": {
    "adapter": "moomoo",
    "venue": {
      "name": "moomoo-us",
      "kind": "live",
      "symbol": "US.AAPL"
    },
    "min_interval_sec": 5.0,
    "record_trades": false,
    "record_orderbook": false
  },
  "execution": {
    "mode": "paper",
    "adapter": "paper",
    "venue": {
      "name": "paper-execution",
      "kind": "paper",
      "symbol": "US.AAPL"
    },
    "order_notional": 500.0
  },
  "credentials": {}
}
